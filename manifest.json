{
  "manifest_version": 3,
  "name": "LinkLens – Read Time for Links",
  "version": "1.0.0",
  "description": "Shows estimated read time next to links so you know what is worth clicking before opening.",
  "permissions": ["scripting"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/search*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}